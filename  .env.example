# Rubimedik Monorepo Environment Variables

# --- API (NestJS) ---
PORT=3000
NODE_ENV=development

# Database & Redis
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/rubimedik
REDIS_URL=redis://localhost:6380

# Auth
JWT_SECRET=your-super-secret-key-32-chars-at-least
JWT_REFRESH_SECRET=your-refresh-secret-key-32-chars
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Payments (Paystack)
PAYSTACK_SECRET_KEY=sk_test_xxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxx

# Email (Resend)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@rubimedik.com

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Business Logic
PLATFORM_FEE_PERCENT=20
REFERRAL_POINT_VALUE=500
FOLLOWUP_WINDOW_DAYS=30

# URLs
ADMIN_DASHBOARD_URL=http://localhost:3001
APP_URL=http://localhost:3000

# --- Mobile (Expo) ---
EXPO_PUBLIC_API_URL=http://localhost:3000/v1

# --- Admin (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3000/v1

# Platform Wallet (The admin account that receives platform fees)
PLATFORM_ADMIN_EMAIL=agatevureglory@gmail.com

# Consultation Refund Percentages (0-100)
REFUND_PERCENT_GT_48H=100
REFUND_PERCENT_24_48H=50
REFUND_PERCENT_LT_24H=0
